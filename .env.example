# Copy to .env and fill in.
#
# SUPABASE_DSN: PostgreSQL connection string for the contributor read-only role.
#   Ask the owner for the contributor DSN. Use the Supabase session pooler host

SUPABASE_DSN=postgresql://contributor_bot:PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# LICENSE_API_URL: Supabase Edge Function endpoint that validates license keys.
#   Leave empty for dev-bypass mode (skips license validation entirely).
LICENSE_API_URL=

# UPDATE_MANIFEST_URL: public URL of the auto-update manifest in the Supabase `releases`
#   bucket. Used only by release.py to bake the URL into production builds; the exe URL is
#   derived from it. Owner-only — leave empty for contributor/dev builds.
UPDATE_MANIFEST_URL=https://<project-ref>.supabase.co/storage/v1/object/public/releases/latest.json
